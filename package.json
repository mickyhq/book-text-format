{
  "name": "book-text-formatter",
  "displayName": "Book Text Formatter",
  "description": "Format text for book layouts with margin wrapping, double spacing, and smart cleanup.",
  "version": "0.1.3",
  "publisher": "mickyhq",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mickyhq/book-text-format.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onCommand:book-text-formatter.formatText",
    "onLanguage:plaintext"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "book-text-formatter.formatText",
        "title": "Book Formatter: Format Text Layout"
      }
    ],
    "keybindings": [
      {
        "command": "book-text-formatter.formatText",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "book-text-formatter.formatText",
          "when": "editorTextFocus",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Book Text Formatter",
      "properties": {
        "bookTextFormatter.marginWidth": {
          "type": "number",
          "default": 80,
          "minimum": 20,
          "maximum": 500,
          "description": "Maximum number of characters per line when wrapping text."
        },
        "bookTextFormatter.doubleSpacing": {
          "type": "boolean",
          "default": true,
          "description": "Insert an empty line between every line of text."
        },
        "bookTextFormatter.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format plain text files on save."
        },
        "bookTextFormatter.formatOnSaveFileTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "plaintext",
            "txt"
          ],
          "description": "Language IDs or file extensions (with dot, e.g. '.txt') to format on save."
        },
        "bookTextFormatter.firstLineIndent": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 20,
          "description": "Number of spaces to indent the first line of each paragraph (0 = no indent)."
        },
        "bookTextFormatter.justifyText": {
          "type": "boolean",
          "default": false,
          "description": "Justify text by padding lines with spaces so both left and right edges align at the margin."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "mocha": "^11.7.6",
    "typescript": "^5.3.0"
  }
}
